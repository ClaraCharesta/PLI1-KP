<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Pivot Dashboard Legend Toggle</title>

<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/sidebar.css">
<link rel="stylesheet" href="/css/topbar.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
  background:#f4f6f9;
}

/* GRID */
.grid {
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:20px;
  padding:20px;
}

/* CARD */
.card {
  background:#fff;
  border-radius:16px;
  padding:15px;
  box-shadow:0 6px 18px rgba(0,0,0,.08);
}

/* HEADER */
.header {
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:10px;
}

/* CHART AREA */
.center {
  position:relative;
  height:260px;
}

/* CANVAS */
.center canvas,
#expandCanvas {
  position:absolute;
  width:100% !important;
  height:100% !important;
}

/* CENTER TEXT */
.total {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  font-size:28px;
  font-weight:900;
  color:#111827;
  pointer-events:none;
  z-index:2;
}

/* BUTTON */
button {
  background:#111827;
  color:#fff;
  border:none;
  padding:7px 12px;
  border-radius:8px;
  cursor:pointer;
}

button:hover {
  background:#374151;
}

/* MODAL */
.modal {
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.65);
  justify-content:center;
  align-items:center;
  z-index:999;
}

.modalContent {
  background:#fff;
  width:85%;
  height:85%;
  border-radius:16px;
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
}

/* WRAP */
.expandWrap {
  position:relative;
  width:100%;
  height:100%;
}

/* TOTAL MODAL */
#expandTotal {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  font-size:34px;
  font-weight:900;
  color:#111827;
  pointer-events:none;
}

/* CLOSE */
.closeBtn {
  position:absolute;
  top:12px;
  right:12px;
  background:#ef4444;
  border:none;
  padding:8px 12px;
  border-radius:10px;
  color:white;
  cursor:pointer;
  z-index:10;
}
</style>
</head>

<body>
<%- include('partials/sidebar') %>

<div class="main">
<%- include('partials/topbar',{title:"Pivot Dashboard"}) %>

<div style="padding:20px 20px 0 20px;">
  <button onclick="goBack()" style="margin-bottom:10px;">
    ← Back
  </button>
</div>

<div class="grid" id="grid"></div>

<!-- MODAL -->
<div id="expandModal" class="modal">
  <div class="modalContent">
    <button class="closeBtn" onclick="closeExpand()">X</button>

    <div class="expandWrap">
      <canvas id="expandCanvas"></canvas>
      <div id="expandTotal"></div>
    </div>

  </div>
</div>

<script>
const chartsData = <%- JSON.stringify(charts) %>;

const keys = ["area","kepala","durasi","frek","status","stop"];

const titles = [
  "Pivot BM Area",
  "Pivot BM Kepala Shift",
  "Pivot Durasi TS",
  "Pivot Frekuensi TS",
  "Pivot Status BM",
  "Pivot Stop Alat"
];

/* warna pekat */
const colors = ["#1E3A8A","#0F766E","#B91C1C","#92400E","#6D28D9","#047857","#DC2626"];

let chartObjs = {};
let expandChartObj = null;
let currentKey = null;

/* HITUNG TOTAL VISIBEL */
function getVisibleTotal(chart){
  let sum = 0;
  chart.data.datasets[0].data.forEach((val,i)=>{
    if(chart.getDataVisibility(i)) sum += val;
  });
  return sum;
}

/* UPDATE CENTER TEXT */
function updateCenter(chart, elId){
  document.getElementById(elId).innerText = getVisibleTotal(chart);
}

/* INIT CARD */
const grid = document.getElementById("grid");

keys.forEach((k,i)=>{
  grid.innerHTML += `
    <div class="card">
      <div class="header">
        <b>${titles[i]}</b>
        <button onclick="openExpand('${k}')">Expand</button>
      </div>

      <div class="center">
        <canvas id="c_${k}"></canvas>
        <div class="total" id="t_${k}">${chartsData[k].total}</div>
      </div>
    </div>
  `;
});

/* CREATE CHART (CARD) */
function createChart(key){
  const ctx = document.getElementById("c_"+key);

  chartObjs[key] = new Chart(ctx,{
    type:"doughnut",
    data:{
      labels:chartsData[key].labels,
      datasets:[{
        data:chartsData[key].values,
        backgroundColor:colors
      }]
    },
    options:{
      cutout:"70%",
      responsive:true,
      maintainAspectRatio:false,

      plugins:{
        legend:{
          position:"bottom",

          /* 🔥 INI KUNCI CLICK LEGEND */
          onClick:(e,legendItem,legend)=>{
            const index = legendItem.index;
            const chart = legend.chart;

            chart.toggleDataVisibility(index);
            chart.update();

            updateCenter(chart, "t_"+key);
          }
        }
      },

      /* update after animation */
      onUpdate:(chart)=>{
        updateCenter(chart, "t_"+key);
      }
    }
  });
}

/* OPEN MODAL */
function openExpand(key){
  currentKey = key;
  document.getElementById("expandModal").style.display="flex";

  const data = chartsData[key];

  if(expandChartObj) expandChartObj.destroy();

  expandChartObj = new Chart(document.getElementById("expandCanvas"),{
    type:"doughnut",
    data:{
      labels:data.labels,
      datasets:[{
        data:data.values,
        backgroundColor:colors
      }]
    },
    options:{
      cutout:"65%",
      responsive:true,
      maintainAspectRatio:false,

      plugins:{
        legend:{
          position:"right",

          onClick:(e,legendItem)=>{
            const i = legendItem.index;

            expandChartObj.toggleDataVisibility(i);
            expandChartObj.update();

            document.getElementById("expandTotal").innerText =
              getVisibleTotal(expandChartObj);
          }
        }
      }
    }
  });

  document.getElementById("expandTotal").innerText =
    getVisibleTotal(expandChartObj);
}

/* CLOSE */
function closeExpand(){
  document.getElementById("expandModal").style.display="none";
  if(expandChartObj) expandChartObj.destroy();
}

/* INIT ALL */
keys.forEach(k=>createChart(k));

function goBack(){
  window.location.href = "/chart";
}

</script>

</body>
</html>