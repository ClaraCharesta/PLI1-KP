<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ganti Password - PLI 1 Maintenance</title>

  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/topbar.css">
  <link rel="stylesheet" href="/css/sidebar.css">
  <link rel="stylesheet" href="/css/ubahPassword.css">
</head>
<body>

  <%- include('partials/sidebar') %>

  <div class="main">
    <%- include('partials/topbar') %>

    <div class="content">

      <div class="password-container">

        <!-- PROFIL SECTION -->
        <div class="password-section">

          <!-- Password Form -->
          <form id="passwordForm" class="password-form" method="POST" action="/profile/ubah-password">
            
            <div class="password-group">
              <label for="oldPassword">Password Lama</label>
              <div class="password-input-wrapper">
                <input type="password" id="oldPassword" name="oldPassword" placeholder="Masukkan password lama" required>
                <button type="button" class="toggle-password" data-target="oldPassword">
                  <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
              </div>
            </div>

            <div class="password-group">
              <label for="newPassword">Password Baru</label>
              <div class="password-input-wrapper">
                <input type="password" id="newPassword" name="newPassword" placeholder="Masukkan password baru" required>
                <button type="button" class="toggle-password" data-target="newPassword">
                  <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
              </div>
            </div>

            <div class="password-group">
              <label for="confirmPassword">Konfirmasi Password Baru</label>
              <div class="password-input-wrapper">
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Konfirmasi password baru" required>
                <button type="button" class="toggle-password" data-target="confirmPassword">
                  <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="password-actions">
              <button type="submit" class="btn-save">Simpan Perubahan</button>
              <button type="button" class="btn-cancel" id="cancelBtn">Cancel</button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>

  <script src="/js/ubahPassword.js"></script>
</body>
</html>
